<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StudyTimer</title>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <div id="root">
      <main class="app">
        <section class="timer-card" aria-labelledby="app-title">
          <p class="eyebrow">Focus Session</p>
          <h1 id="app-title">StudyTimer</h1>
          <p class="description">Track your study sessions with a simple, distraction-free timer.</p>

          <div class="time-display" id="time-display" aria-live="polite">00:00:00</div>

          <div class="controls">
            <button id="start-button" class="button primary" type="button">Start</button>
            <button id="stop-button" class="button" type="button">Stop</button>
            <button id="reset-button" class="button danger" type="button">Reset</button>
          </div>
        </section>
      </main>
    </div>

    <script src="script.js"></script>
  </body>
</html>
