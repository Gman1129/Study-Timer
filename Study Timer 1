<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StudyTimer</title>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <div id="root">
      <main class="app">
        <section class="timer-card" aria-labelledby="app-title">
          <p class="eyebrow">Focus Session</p>
          <h1 id="app-title">StudyTimer</h1>
          <p class="description">Track your study sessions with a simple, distraction-free timer.</p>

          <div class="time-display" id="time-display" aria-live="polite">00:00:00</div>

          <div class="controls">
            <button id="start-button" class="button primary" type="button">Start</button>
            <button id="stop-button" class="button" type="button">Stop</button>
            <button id="reset-button" class="button danger" type="button">Reset</button>
          </div>
        </section>
      </main>
    </div>

    <script src="script.js"></script>
  </body>
</html>

:root {
  color-scheme: light;
  --bg: #f3f6fb;
  --card: rgba(255, 255, 255, 0.92);
  --text: #1f2937;
  --muted: #6b7280;
  --primary: #2563eb;
  --primary-dark: #1d4ed8;
  --danger: #dc2626;
  --danger-dark: #b91c1c;
  --border: rgba(148, 163, 184, 0.25);
  --shadow: 0 20px 45px rgba(15, 23, 42, 0.12);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  font-family: Arial, Helvetica, sans-serif;
  color: var(--text);
  background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 50%, #f8fafc 100%);
}

#root {
  min-height: 100vh;
}

.app {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 24px;
}

.timer-card {
  width: min(100%, 420px);
  padding: 32px;
  border-radius: 24px;
  background: var(--card);
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
  text-align: center;
  backdrop-filter: blur(12px);
}

.eyebrow {
  margin: 0 0 8px;
  font-size: 0.85rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--primary);
  font-weight: 700;
}

h1 {
  margin: 0;
  font-size: clamp(2rem, 4vw, 2.6rem);
}

.description {
  margin: 12px 0 28px;
  color: var(--muted);
  line-height: 1.5;
}

.time-display {
  margin-bottom: 28px;
  padding: 22px;
  border-radius: 18px;
  background: #0f172a;
  color: #f8fafc;
  font-size: clamp(2rem, 7vw, 3rem);
  font-weight: 700;
  letter-spacing: 0.08em;
}

.controls {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.button {
  border: none;
  border-radius: 14px;
  padding: 14px 16px;
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
  background: #e5e7eb;
  cursor: pointer;
  transition: transform 0.15s ease, background-color 0.15s ease, box-shadow 0.15s ease;
}

.button:hover,
.button:focus-visible {
  transform: translateY(-1px);
  box-shadow: 0 10px 20px rgba(15, 23, 42, 0.12);
}

.button:focus-visible {
  outline: 3px solid rgba(37, 99, 235, 0.35);
  outline-offset: 2px;
}

.button.primary {
  background: var(--primary);
  color: #fff;
}

.button.primary:hover,
.button.primary:focus-visible {
  background: var(--primary-dark);
}

.button.danger {
  background: var(--danger);
  color: #fff;
}

.button.danger:hover,
.button.danger:focus-visible {
  background: var(--danger-dark);
}

@media (max-width: 480px) {
  .timer-card {
    padding: 24px;
  }

  .controls {
    grid-template-columns: 1fr;
  }
}
